# Copy this file to .env for local testing, or paste these as
# Environment Variables in your hosting provider's dashboard.
# Values come from your YugabyteDB Aeon cluster's "Connect" > "YSQL" tab.

PGHOST=your-cluster-host.yugabyte.cloud
PGPORT=5433
PGDATABASE=joybox
PGUSER=admin
PGPASSWORD=your-db-password

# Any long random string — used to sign login session cookies
SESSION_SECRET=change-this-to-something-random

PORT=3000
